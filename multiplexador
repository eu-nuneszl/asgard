#include <Wire.h>
#include "Adafruit_TCS34725.h"

// ====== MULTIPLEXADOR ======
#define TCA_ADDR 0x70

void tcaSelect(uint8_t i) {
  if (i > 7) return;

  Wire.beginTransmission(TCA_ADDR);
  Wire.write(1 << i);
  Wire.endTransmission();
}

// ====== SENSORES DE COR ======
Adafruit_TCS34725 tcs = Adafruit_TCS34725(
  TCS34725_INTEGRATIONTIME_50MS,
  TCS34725_GAIN_4X
);

float hue, saturation, brightness;

// ====== PONTE H ======
#define IN1 7
#define IN2 6
#define IN3 5
#define IN4 4

#define VELOCIDADE 150

// ====== LINHA ======
#define S_ESQ 17
#define S_DIR 15

void setup() {
  Serial.begin(9600);
  Wire.begin();

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(S_ESQ, INPUT);
  pinMode(S_DIR, INPUT);

  // Inicializa sensor ESQUERDO
  tcaSelect(0);
  if (!tcs.begin()) {
    Serial.println("Erro sensor ESQ");
    while (1);
  }

  // Inicializa sensor DIREITO
  tcaSelect(1);
  if (!tcs.begin()) {
    Serial.println("Erro sensor DIR");
    while (1);
  }

  Serial.println("Tudo OK");
}

void loop() {
  int esq = digitalRead(S_ESQ);
  int dir = digitalRead(S_DIR);

  // ====== INTERSEÇÃO ======
  if (esq == 0 && dir == 0) {

    String corE = lerCor(0);
    String corD = lerCor(1);

    Serial.print("E: "); Serial.print(corE);
    Serial.print(" | D: "); Serial.println(corD);

    if (corE == "verde") {
      esquerda();
      delay(400);
    }
    else if (corD == "verde") {
      direita();
      delay(400);
    }
    else {
      frente();
    }
  }

  // ====== NORMAL ======
  else if (esq == 0 && dir == 1) {
    esquerda();
  }
  else if (esq == 1 && dir == 0) {
    direita();
  }
  else {
    parar();
  }
}

// ====== LEITURA DE COR ======

String lerCor(int canal) {
  tcaSelect(canal);

  uint16_t r, g, b, c;
  tcs.getRawData(&r, &g, &b, &c);

  rgbToHSB(r, g, b);

  if (saturation < 0.1) return "nenhuma";

  if (hue >= 75 && hue <= 150) return "verde";

  return "outra";
}

// ====== CONVERSÃO ======

void rgbToHSB(int r, int g, int b) {
  float R = r;
  float G = g;
  float B = b;

  float max_val = max(R, max(G, B));
  float min_val = min(R, min(G, B));
  float delta = max_val - min_val;

  brightness = max_val;

  if (max_val == 0) saturation = 0;
  else saturation = delta / max_val;

  if (delta == 0) {
    hue = 0;
    return;
  }

  if (max_val == R) hue = 60 * fmod(((G - B) / delta), 6);
  else if (max_val == G) hue = 60 * (((B - R) / delta) + 2);
  else hue = 60 * (((R - G) / delta) + 4);

  if (hue < 0) hue += 360;
}

// ====== MOVIMENTO ======

void frente() {
  analogWrite(IN1, VELOCIDADE); analogWrite(IN2, 0);
  analogWrite(IN3, VELOCIDADE); analogWrite(IN4, 0);
}

void esquerda() {
  analogWrite(IN1, 0); analogWrite(IN2, VELOCIDADE);
  analogWrite(IN3, VELOCIDADE); analogWrite(IN4, 0);
}

void direita() {
  analogWrite(IN1, VELOCIDADE); analogWrite(IN2, 0);
  analogWrite(IN3, 0); analogWrite(IN4, VELOCIDADE);
}

void parar() {
  analogWrite(IN1, 0); analogWrite(IN2, 0);
  analogWrite(IN3, 0); analogWrite(IN4, 0);
}
