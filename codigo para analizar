#include <Wire.h>
#include "Adafruit_TCS34725.h"

// ===== CONFIGURAÇÕES DE HARDWARE (ARDUINO MEGA) =====

// No Mega, SDA = 20 e SCL = 21. A biblioteca Wire usa esses pinos automaticamente.
#define TCA_ADDR 0x70

// Sensores de linha (Pinos digitais padrão)
#define S1 45
#define S2 14
#define S3 15
#define S4 44

// Motores (Conectados em pinos PWM do Mega)
#define IN1 7
#define IN2 6
#define IN3 5
#define IN4 4
#define ENA 8 // PWM Motor Esquerdo
#define ENB 9 // PWM Motor Direito

// ===== PARÂMETROS DE CONTROLE =====
int baseSpeed = 130; 
float Kp = 30.0;     
float Kd = 15.0;     
int ultimoErro = 0;

// Sensor de cor (24ms de integração para resposta rápida em competições)
Adafruit_TCS34725 tcs = Adafruit_TCS34725(TCS34725_INTEGRATIONTIME_24MS, TCS34725_GAIN_4X);

// ===== FUNÇÃO DO MULTIPLEXADOR =====
void tcaSelect(uint8_t i) {
  if (i > 7) return;
  Wire.beginTransmission(TCA_ADDR);
  Wire.write(1 << i);
  Wire.endTransmission();
}

// ===== CONTROLE DOS MOTORES =====
void mover(int velEsq, int velDir) {
  // Motor Esquerdo
  if (velEsq >= 0) {
    digitalWrite(IN1, HIGH);
    digitalWrite(IN2, LOW);
  } else {
    digitalWrite(IN1, LOW);
    digitalWrite(IN2, HIGH);
    velEsq = -velEsq;
  }

  // Motor Direito
  if (velDir >= 0) {
    digitalWrite(IN3, HIGH);
    digitalWrite(IN4, LOW);
  } else {
    digitalWrite(IN3, LOW);
    digitalWrite(IN4, HIGH);
    velDir = -velDir;
  }

  // No Mega, analogWrite funciona em todos os pinos de 2 a 13.
  analogWrite(ENA, constrain(velEsq, 0, 255));
  analogWrite(ENB, constrain(velDir, 0, 255));
}

// ===== DETECÇÃO DE VERDE (CALIBRADA PARA OBR) =====
bool detectaVerde(uint8_t canal) {
  tcaSelect(canal);

  uint16_t r, g, b, c;
  tcs.getRawData(&r, &g, &b, &c);

  // Se a luz estiver muito baixa, ignora (evita leitura de erro no preto)
  if (c < 50) return false;

  // Lógica de comparação direta (veloz para o Mega)
  // O verde deve ser 30% maior que o vermelho e maior que o azul
  if (g > (r * 1.3) && g > b) {
    return true;
  }
  return false;
}

// ===== MANOBRAS AUTOMATIZADAS =====
void realizarGiro(int vEsq, int vDir, int tempo) {
  mover(vEsq, vDir);
  delay(tempo); 
  // Freio ativo: reverte os motores por um milissegundo antes de parar
  mover(-vEsq, -vDir); 
  delay(10);
  mover(0, 0);
  delay(50);
}

// ===== SETUP =====
void setup() {
  // Inicia comunicação I2C nos pinos 20 e 21 automaticamente no Mega
  Wire.begin();
  Serial.begin(9600);

  // Inicializa o sensor nos canais 0 e 1 do multiplexador
  tcaSelect(0);
  tcs.begin();
  
  tcaSelect(1);
  tcs.begin();

  // Configuração de pinos de entrada e saída
  pinMode(S1, INPUT); pinMode(S2, INPUT);
  pinMode(S3, INPUT); pinMode(S4, INPUT);
  
  pinMode(IN1, OUTPUT); pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT); pinMode(IN4, OUTPUT);
  pinMode(ENA, OUTPUT); pinMode(ENB, OUTPUT);

  Serial.println("Robô Mega Iniciado!");
}

// ===== LOOP PRINCIPAL =====
void loop() {
  
  // 1. VERIFICAÇÃO DE INTERSEÇÕES (VERDE)
  bool verdeEsq = detectaVerde(0);
  bool verdeDir = detectaVerde(1);

  if (verdeEsq && verdeDir) {
    realizarGiro(150, -150, 650); // Meia volta
    return;
  } 
  else if (verdeEsq) {
    realizarGiro(-120, 150, 320); // Giro 90 esquerda
    return;
  } 
  else if (verdeDir) {
    realizarGiro(150, -120, 320); // Giro 90 direita
    return;
  }

  // 2. LEITURA DOS SENSORES DE LINHA
  // '!' assume que seu sensor retorna 0 no PRETO e 1 no BRANCO
  int s1 = !digitalRead(S1);
  int s2 = !digitalRead(S2);
  int s3 = !digitalRead(S3);
  int s4 = !digitalRead(S4);

  // 3. CÁLCULO DO ERRO (PESOS)
  int erro = (s1 * -3) + (s2 * -1) + (s3 * 1) + (s4 * 3);

  // 4. MEMÓRIA DE LINHA (Se sair da linha, gira forte para o último lado visto)
  if (s1 == 0 && s2 == 0 && s3 == 0 && s4 == 0) {
    if (ultimoErro > 0) erro = 5;
    else if (ultimoErro < 0) erro = -5;
    else erro = 0;
  }

  // 5. CONTROLE PD (PROPORCIONAL DERIVATIVO)
  int deltaErro = erro - ultimoErro;
  int correcao = (erro * Kp) + (deltaErro * Kd);
  ultimoErro = erro;

  // 6. CÁLCULO DAS VELOCIDADES FINAIS
  int velEsq = baseSpeed + correcao;
  int velDir = baseSpeed - correcao;

  // Aplica movimento
  mover(velEsq, velDir);

  // Delay de estabilidade (O Mega é rápido, 2ms ajuda a não sobrecarregar o I2C)
  delay(2);
}
